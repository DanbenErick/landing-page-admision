---
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div>
        <a href="/" class="header__brand" style="margin-bottom: var(--space-2); display: inline-flex;">
          <img src="/img/logo.jpg" alt="Logo UNDAC" class="header__logo" width="44" height="44" />
          <div class="header__title" style="color: var(--color-white);">
            ADMISIÓN UNDAC
            <span style="color: var(--color-gray-400);">UNDAC</span>
          </div>
        </a>
        <p class="footer__brand-desc">
          Portal oficial de Admisión de la Universidad Nacional Daniel Alcides Carrión. Información sobre procesos de admisión, modalidades de ingreso y escuelas profesionales.
        </p>
        <div class="footer__social">
          <a href="https://facebook.com/UNDAC" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://twitter.com/UNDAC" class="footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
          </a>
          <a href="https://youtube.com/UNDAC" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
          <a href="https://instagram.com/UNDAC" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="footer__title">Enlaces Rápidos</h3>
        <nav class="footer__links" aria-label="Enlaces del pie de página">
          <a href="/" class="footer__link">Inicio</a>
          <a href="/modalidades" class="footer__link">Modalidades de Ingreso</a>
          <a href="/escuelas-profesionales" class="footer__link">Escuelas Profesionales</a>
          <a href="/documentos" class="footer__link">Documentos</a>
          <a href="/noticias" class="footer__link">Noticias</a>
          <a href="/preguntas-frecuentes" class="footer__link">Preguntas Frecuentes</a>
        </nav>
      </div>

      <!-- Schedule -->
      <div>
        <h3 class="footer__title">Horario de Atención</h3>
        <ul class="footer__links">
          <li style="display: flex; flex-direction: column; gap: 4px;">
            <span style="font-weight: 600; color: var(--color-white);">Lunes a Viernes</span>
            <span style="opacity: 0.8;">Mañanas: 08:00 AM - 01:00 PM</span>
            <span style="opacity: 0.8;">Tardes: 02:00 PM - 05:00 PM</span>
          </li>
          <li style="display: flex; flex-direction: column; gap: 4px; margin-top: 12px;">
            <span style="font-weight: 600; color: var(--color-white);">Sábados (Sólo Informes)</span>
            <span style="opacity: 0.8;">09:00 AM - 12:00 PM</span>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="footer__title">Contacto</h3>
        <ul class="footer__links">
          <li style="display: flex; gap: var(--space-2); align-items: flex-start;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>Ciudad Universitaria, San Juan pampa<br/>Yanacancha - Pasco</span>
          </li>
          <li style="display: flex; gap: var(--space-2); align-items: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>(063) 421000 - Anexo 104</span>
          </li>
          <li style="display: flex; gap: var(--space-2); align-items: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:admision@undac.edu.pe" style="color: inherit; text-decoration: none;">admision@undac.edu.pe</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__bottom-text">
        © 2026 Universidad Nacional Daniel Alcides Carrión. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
