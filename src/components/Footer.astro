---
// Footer Component
---

<!-- Global Footer -->
<footer style="background: var(--color-gray-900); color: var(--color-white); padding: var(--space-16) 0 var(--space-8); margin-top: auto;">
  <div class="container">
    <div class="grid grid--4" style="gap: var(--space-8); margin-bottom: var(--space-12);">
      <!-- Column 1: Brand & Description -->
      <div>
        <div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6);">
          <div style="background: white; padding: 4px; border-radius: 50%;">
            <img src="/img/logo.jpg" alt="Logo UNDAC" style="width: 48px; height: 48px; border-radius: 50%; opacity: 0.9;" />
          </div>
          <div>
            <div style="font-weight: 800; font-size: var(--font-size-lg); letter-spacing: -0.5px;">ADMISIÓN UNDAC</div>
            <div style="font-size: var(--font-size-xs); color: var(--color-gray-400); letter-spacing: 1px;">UNDAC</div>
          </div>
        </div>
        <p style="color: var(--color-gray-400); font-size: var(--font-size-sm); line-height: 1.8;">
          Portal oficial de Admisión de la Universidad Nacional Daniel Alcides Carrión. Información sobre procesos de admisión, modalidades de ingreso y escuelas profesionales.
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h4 style="font-size: var(--font-size-lg); font-weight: 700; margin-bottom: var(--space-6); color: var(--color-white);">Enlaces Rápidos</h4>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-3);">
          <li><a href="/" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Inicio</a></li>
          <li><a href="/modalidades" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Modalidades de Ingreso</a></li>
          <li><a href="/escuelas" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Escuelas Profesionales</a></li>
          <li><a href="/documentos" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Documentos</a></li>
          <li><a href="/noticias" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Noticias</a></li>
          <li><a href="/contacto" style="color: var(--color-gray-400); text-decoration: none; transition: color 0.2s;">Preguntas Frecuentes</a></li>
        </ul>
      </div>

      <!-- Column 3: Schedule -->
      <div>
        <h4 style="font-size: var(--font-size-lg); font-weight: 700; margin-bottom: var(--space-6); color: var(--color-white);">Horario de Atención</h4>
        <div style="display: flex; flex-direction: column; gap: var(--space-4);">
          <div>
            <strong style="color: var(--color-primary-100); font-size: var(--font-size-sm); display: block; margin-bottom: 2px;">Lunes a Viernes</strong>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm);">Mañanas: 08:00 AM - 01:00 PM</div>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm);">Tardes: 02:00 PM - 05:00 PM</div>
          </div>
          <div>
            <strong style="color: var(--color-primary-100); font-size: var(--font-size-sm); display: block; margin-bottom: 2px;">Sábados (Sólo Informes)</strong>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm);">09:00 AM - 12:00 PM</div>
          </div>
        </div>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 style="font-size: var(--font-size-lg); font-weight: 700; margin-bottom: var(--space-6); color: var(--color-white);">Contacto</h4>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-4);">
          <li style="display: flex; gap: var(--space-3); align-items: flex-start;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-100)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm); line-height: 1.6;">
              Ciudad Universitaria, San Juan pampa<br/>Yanacancha - Pasco
            </div>
          </li>
          <li style="display: flex; gap: var(--space-3); align-items: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-100)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm);">(063) 421000 - Anexo 104</div>
          </li>
          <li style="display: flex; gap: var(--space-3); align-items: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-100)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <div style="color: var(--color-gray-400); font-size: var(--font-size-sm);">admision@undac.edu.pe</div>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright/Bottom -->
    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: var(--space-6); display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: var(--space-4);">
      <p style="color: var(--color-gray-500); font-size: var(--font-size-sm); margin: 0;">
        &copy; {new Date().getFullYear()} Dirección General de Admisión UNDAC. Todos los derechos reservados.
      </p>
      <div style="display: flex; gap: var(--space-4);">
        <a href="#" style="color: var(--color-gray-500); text-decoration: none; font-size: var(--font-size-sm); transition: color 0.2s;">Políticas de Privacidad</a>
        <a href="#" style="color: var(--color-gray-500); text-decoration: none; font-size: var(--font-size-sm); transition: color 0.2s;">Términos de Uso</a>
      </div>
    </div>
  </div>
</footer>
