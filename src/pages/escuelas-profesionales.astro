---

<Layout
  title="Escuelas Profesionales | Admisión UNDAC"
  description="Conoce las escuelas profesionales de la UNDAC agrupadas por áreas: Ingenierías, Salud, Empresariales y Ciencias Sociales."
  keywords="escuelas profesionales, carreras, UNDAC, ingeniería, medicina, derecho, contabilidad"
>
  <Header slot="header" />

  <PageHero title="Escuelas Profesionales" breadcrumb="Escuelas Profesionales" />

  <section class="section">
    <div class="container">
      {areas.map(area => (
        <div class="area-group" data-reveal>
          <h2 class="area-group__title">
            <span set:html={area.icon}></span>
            {area.name}
          </h2>
          <div class="career-card-grid">
            {area.careers.map(career => (
              <div class="career-box">
                <div class="career-box__title">{career.name}</div>
                <p class="career-box__desc">{career.desc}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
