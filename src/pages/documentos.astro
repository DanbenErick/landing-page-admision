---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import '../styles/global.css';

import documents from '../data/documentos.json';
---

<Layout
  title="Documentos | Admisión UNDAC"
  description="Descarga los documentos oficiales del proceso de admisión UNDAC: reglamento, prospecto, cronograma y guía del postulante."
  keywords="documentos, reglamento admisión, prospecto, cronograma, descarga, UNDAC"
>
  <Header slot="header" />

  <PageHero title="Documentos" breadcrumb="Documentos" />

  <section class="section">
    <div class="container">
      <h2 class="section__title">Documentos Oficiales</h2>
      <p class="section__subtitle">Descarga los documentos necesarios para tu proceso de admisión</p>
      <div class="doc-grid" data-reveal>
        {documents.map(doc => (
          <a href={doc.file} class="doc-card" download aria-label={`Descargar ${doc.name}`}>
            <div class="doc-card__header">
              <div class="doc-card__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              </div>
              <div class="doc-card__dl-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              </div>
            </div>
            <div class="doc-card__name">{doc.name}</div>
            <div class="doc-card__size">{doc.size}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
