---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import '../styles/global.css';

const procesosSeleccion = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>',
    title: 'Examen Ordinario',
    desc: 'Modalidad principal de ingreso a la UNDAC. Se evalúan conocimientos generales y específicos según el área de la carrera elegida.',
    requirements: ['DNI vigente', 'Certificado de estudios de secundaria completa', 'Pago por derecho de inscripción (S/ 301 Estatal, S/ 351 Particular)', '2 fotografías tamaño carnet']
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>',
    title: 'CEPRE UNDAC',
    desc: 'Centro Preuniversitario de la UNDAC. Los estudiantes que completan satisfactoriamente el ciclo académico obtienen vacante directa.',
    requirements: ['Haber culminado el ciclo CEPRE UNDAC', 'Certificado de estudios secundarios', 'DNI vigente', 'Constancia de notas del CEPRE', 'Pago por derecho de inscripción (S/ 301 Estatal, S/ 351 Particular)']
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>',
    title: 'Primera Selección (5tos)',
    desc: 'Ingreso para estudiantes del quinto de secundaria de instituciones educativas públicas y privadas de la región.',
    requirements: ['Certificado de quinto superior o constancia equivalente', 'DNI vigente', 'Constancia de matrícula del 5to año de secundaria', 'Carta de presentación del colegio', 'Pago por derecho de inscripción (S/ 301 Estatal, S/ 351 Particular)']
  }
];

const modalidades = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3v6h-6"></path><path d="M7 21v-6h6"></path><path d="M21 9l-4-4L6 16.5"></path><path d="M3 15l4 4 11-11.5"></path></svg>',
    title: 'Traslado Externo',
    desc: 'Para estudiantes provenientes de otras universidades nacionales o extranjeras que desean continuar sus estudios en la UNDAC.',
    requirements: ['Certificado de estudios universitarios visado', 'Sílabos de asignaturas aprobadas', 'DNI vigente', 'Constancia de matrícula de la universidad de origen']
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>',
    title: 'Personas con Discapacidad',
    desc: 'Modalidad inclusiva para personas con discapacidad certificada, garantizando igualdad de oportunidades en el acceso a la educación.',
    requirements: ['Certificado de discapacidad emitido por entidad competente', 'DNI vigente', 'Certificado de estudios secundarios', 'Resolución de CONADIS']
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>',
    title: 'Deportistas Calificados',
    desc: 'Para deportistas destacados con logros a nivel regional, nacional o internacional debidamente acreditados.',
    requirements: ['Constancia del IPD', 'Documentos que acrediten logros deportivos', 'DNI vigente', 'Certificado de estudios secundarios']
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>',
    title: 'Titulados o Graduados',
    desc: 'Para profesionales con título o grado académico que desean cursar una segunda carrera profesional en la UNDAC.',
    requirements: ['Copia legalizada del título profesional o grado', 'DNI vigente', 'Certificado de estudios universitarios', 'Pago por derecho de inscripción']
  }
];
---

<Layout
  title="Modalidades de Ingreso | Admisión UNDAC"
  description="Conoce las modalidades de ingreso a la UNDAC: examen ordinario, CEPRE, quinto superior, traslado externo, deportistas calificados y más."
  keywords="modalidades ingreso, examen admisión, CEPRE UNDAC, traslado, quinto superior, UNDAC"
>
  <Header slot="header" />

  <PageHero title="Modalidades de Ingreso" breadcrumb="Modalidades" />

  <section class="section">
    <div class="container">
      <div class="area-group" data-reveal>
        <h2 class="area-group__title">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Procesos de Selección
        </h2>
        <div class="career-card-grid">
          {procesosSeleccion.map(proceso => (
            <div class="modality-card">
              <div class="modality-card__title">
                <span class="modality-card__icon" set:html={proceso.icon}></span>
                {proceso.title}
              </div>
              <p class="modality-card__desc">{proceso.desc}</p>
              <div class="modality-card__requirements">
                <strong>Requisitos generales:</strong>
                <ul>
                  {proceso.requirements.map(req => <li>{req}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="area-group" data-reveal style="margin-top: var(--space-12);">
        <h2 class="area-group__title">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 16 16 12 12 8"></polyline><line x1="8" y1="12" x2="16" y2="12"></line></svg>
          Modalidades de Ingreso Especiales
        </h2>
        <p class="section__subtitle" style="margin-bottom: var(--space-6);">La UNDAC garantiza igualdad de oportunidades a través de estas modalidades para distintos grupos.</p>
        <div class="career-card-grid">
          {modalidades.map(mod => (
            <div class="modality-card">
              <div class="modality-card__title">
                <span class="modality-card__icon" set:html={mod.icon}></span>
                {mod.title}
              </div>
              <p class="modality-card__desc">{mod.desc}</p>
              <div class="modality-card__requirements">
                <strong>Requisitos generales:</strong>
                <ul>
                  {mod.requirements.map(req => <li>{req}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
