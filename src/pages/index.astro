---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import HeroSlider from '../components/HeroSlider.astro';
const cronograma = [
  { day: "15", month: "ENE", title: "Inicio de Inscripciones", text: "Apertura de pagos en el Banco de la Nación y registro de postulantes a través del portal web institucional para todas las modalidades.", highlight: true, primaryStyle: true, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>` },
  { day: "05", month: "MAR", title: "Examen Extraordinario y CEPRE UNDAC", text: "Evaluación exclusiva para primeros puestos, graduados, deportistas calificados, víctimas de terrorismo y postulantes CEPRE.", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>` },
  { day: "12", month: "MAR", title: "Cierre de Inscripciones (Ordinario)", text: "Último día para el pago por derecho de examen de admisión ordinario y validación de expedientes.", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>` },
  { day: "22", month: "MAR", title: "Examen General de Admisión", text: "Evaluación presencial modalidad Ordinaria. El ingreso a la Ciudad Universitaria será desde las 07:00 a.m. hasta las 09:00 a.m.", highlight: true, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>` },
  { day: "23", month: "MAR", title: "Publicación de Resultados", text: "Publicación del cuadro de méritos y relación de ingresantes a través de nuestra página web y paneles informativos.", primaryStyle: true, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>` }
];
---

<Layout 
  title="Admisión UNDAC | Universidad Nacional Daniel Alcides Carrión"
  description="Portal oficial de Admisión de la Universidad Nacional Daniel Alcides Carrión (UNDAC). Encuentra cronogramas, requisitos, prospectos, temarios y vacantes para el proceso de admisión 2026."
  keywords="admisión undac, examen de admisión, prospecto undac, temario undac, vacantes undac, ingreso a la universidad, pasco"
>
  <main>
    <!-- Premium Hero Section -->
    <section class="hero-admission" data-reveal>
      <div class="hero-admission__background">
        <img src="/img/banner-admision.jpg" alt="Campus UNDAC" />
        <div class="hero-admission__overlay"></div>
      </div>
      <div class="container hero-admission__content">
        <div class="hero-admission__badge">Proceso de Admisión 2026-I</div>
        <div style="min-height: 110px; display: flex; align-items: flex-end; margin-bottom: var(--space-4);">
          <h1 class="hero-admission__title" style="margin-bottom: 0;"><span id="hero-title-text"></span></h1>
        </div>
        <div style="min-height: 80px; margin-bottom: var(--space-8);">
          <p class="hero-admission__subtitle" style="margin-bottom: 0; opacity: 1;"><span id="hero-subtitle-text"></span></p>
        </div>
        <div class="hero-admission__actions">
          <a href="#cronograma" class="btn btn--primary btn--large">Ver Cronograma</a>
          <a href="/modalidades" class="btn btn--outline btn--outline-white btn--large" style="background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3);">Requisitos de Inscripción</a>
        </div>
      </div>
    </section>

    <!-- Professional Typewriter Animation via Typed.js -->
    <script src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const titleEl = document.getElementById('hero-title-text');
        
        if (titleEl) {
          new Typed('#hero-title-text', {
            strings: ['Tu futuro empieza en la <span class="undac-badge"><span class="undac-un">UN</span><span class="undac-da">DA</span><span class="undac-c">C</span></span>'],
            typeSpeed: 50,
            backSpeed: 0,
            showCursor: true,
            cursorChar: '|',
            contentType: 'html',
            onComplete: (self) => {
              // Hide title cursor after completion
              const titleCursor = document.querySelector('.typed-cursor');
              if (titleCursor) titleCursor.style.opacity = '0';
              
              // Start subtitle typing sequence
              new Typed('#hero-subtitle-text', {
                strings: ['Únete a la universidad licenciada más importante de la región central del país. Excelencia académica al servicio de la sociedad.'],
                typeSpeed: 25,
                showCursor: true,
                cursorChar: '|'
              });
            }
          });
        }
      });
    </script>

    <style is:global>
      /* Standout UNDAC Container Badge */
      .undac-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 4px 16px;
        margin-left: 4px;
        border-radius: 12px;
        border: 2px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 0 10px rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
      }

      /* Specific colors per letter/syllable */
      .undac-un {
        color: #0d6efd; /* Blue */
        text-shadow: 0 2px 10px rgba(13, 110, 253, 0.6);
      }
      
      .undac-da {
        color: #FFFFFF; /* White */
        text-shadow: 0 2px 10px rgba(255, 255, 255, 0.4);
      }

      .undac-c {
        color: #E3000F; /* Red */
        text-shadow: 0 2px 10px rgba(227, 0, 15, 0.6);
      }

      /* Premium Typed.js Cursor */
      .typed-cursor {
        font-weight: 300;
        color: var(--color-white);
        animation: typedjsBlink 0.9s infinite;
        -webkit-animation: typedjsBlink 0.9s infinite;
      }
      @keyframes typedjsBlink {
        50% { opacity: 0.0; }
      }
      @-webkit-keyframes typedjsBlink {
        0% { opacity: 1; }
        50% { opacity: 0.0; }
        100% { opacity: 1; }
      }
    </style>

    <!-- Quick Access Resources (Prospectus, Syllabus, Vacancies) -->
    <section class="section" style="padding-top: 0; margin-top: -60px; position: relative; z-index: 10;" data-reveal>
      <div class="container">
        <div class="grid grid--4" style="gap: var(--space-4);">
          <a href="/documentos#prospecto" class="resource-card">
            <div class="resource-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <div class="resource-card__content">
              <h3>Prospecto</h3>
              <p>Reglamento oficial</p>
            </div>
          </a>
          <a href="/documentos#temario" class="resource-card">
            <div class="resource-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <div class="resource-card__content">
              <h3>Temario</h3>
              <p>Contenidos a evaluar</p>
            </div>
          </a>
          <a href="/documentos#vacantes" class="resource-card">
            <div class="resource-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div class="resource-card__content">
              <h3>Cuadro de Vacantes</h3>
              <p>Distribución por carrera</p>
            </div>
          </a>
          <a href="/modalidades#pagos" class="resource-card">
            <div class="resource-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
            </div>
            <div class="resource-card__content">
              <h3>Derechos de Pago</h3>
              <p>Costos de inscripción</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Schedule (Cronograma) -->
    <section id="cronograma" class="section section--gray" data-reveal>
      <div class="container">
        <div class="section__header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-8);">
          <div>
            <h2 class="section__title">Cronograma del Proceso 2026-I</h2>
            <p class="section__subtitle">Fechas importantes que debes tener en cuenta para tu postulación</p>
          </div>
          <div class="badge badge--active">Proceso Vigente</div>
        </div>

        <div class="timeline">
          {cronograma.map((item) => (
            <div class="timeline__item">
              <div class="timeline__date">
                <span class="timeline__day">{item.day}</span>
                <span class="timeline__month">{item.month}</span>
              </div>
              <div class="timeline__content card" style={
                item.highlight 
                  ? (item.primaryStyle 
                      ? "background: var(--color-primary-50); border-left: 5px solid var(--color-primary); box-shadow: 0 10px 25px rgba(26, 71, 165, 0.1);" 
                      : "background: rgba(255,165,0,0.05); border-left: 5px solid var(--color-accent-dark); box-shadow: 0 10px 25px rgba(249, 168, 37, 0.1);"
                    ) 
                  : "border-left: 4px solid var(--color-gray-300);"
              }>
                <div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-2);">
                  <div style={"display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0; " + (item.primaryStyle ? "background: var(--color-primary); color: white;" : item.highlight ? "background: var(--color-accent-dark); color: white;" : "background: var(--color-secondary-50); color: var(--color-secondary-dark);")} set:html={item.icon}></div>
                  <h3 class="timeline__title" style={"margin: 0; " + (item.primaryStyle ? "color: var(--color-primary-dark); font-weight: 800;" : item.highlight ? "color: var(--color-accent-dark); font-weight: 800;" : "color: var(--color-secondary-dark);")}>
                    {item.title}
                  </h3>
                </div>
                <p class="timeline__text" style="font-size: var(--font-size-md); color: var(--color-gray-700); line-height: 1.6; padding-left: 36px;">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Admission Modalities -->
    <section class="section" data-reveal>
      <div class="container">
        <h2 class="section__title section__title--center">Procesos de Selección y Modalidades</h2>
        <p class="section__subtitle section__subtitle--center">Conoce nuestros principales procesos de admisión y elige la modalidad que se adapte a tu perfil</p>
        
        <div class="grid grid--4">
          <!-- Examen Ordinario -->
          <div class="card card--modality" style="border-top: 4px solid var(--color-primary-light); padding-top: var(--space-2);">
            <div class="card__body">
              <div style="background: var(--color-primary-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--color-primary-light); margin-bottom: var(--space-4);">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              </div>
              <h3 class="card__title">Examen Ordinario</h3>
              <p class="card__text">Dirigido a egresados de Educación Básica Regular (EBR) y Educación Básica Alternativa (EBA) de instituciones a nivel nacional.</p>
              <ul class="check-list">
                <li>Certificado de estudios originales</li>
                <li>DNI vigente (Copia y Original)</li>
                <li>Voucher Banco de la Nación</li>
              </ul>
            </div>
            <div class="card__footer">
              <a href="/modalidades" class="btn btn--outline" style="width: 100%;">Ver detalle completo</a>
            </div>
          </div>

          <!-- Primera Selección -->
          <div class="card card--modality" style="border-top: 4px solid var(--color-primary); padding-top: var(--space-2);">
            <div class="card__body">
              <div style="background: var(--color-primary-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--color-primary); margin-bottom: var(--space-4);">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              </div>
              <h3 class="card__title">Primera Selección (5tos)</h3>
              <p class="card__text">Proceso exclusivo para estudiantes que se encuentren cursando el quinto año de educación secundaria en la región.</p>
              <ul class="check-list">
                <li>Requisitos examen ordinario</li>
                <li>Constancias específicas</li>
                <li>Acreditación de modalidad</li>
              </ul>
            </div>
            <div class="card__footer">
              <a href="/modalidades" class="btn btn--outline" style="width: 100%;">Consultar requisitos</a>
            </div>
          </div>

          <!-- CEPRE -->
          <div class="card card--modality" style="border-top: 4px solid var(--color-primary-dark); padding-top: var(--space-2);">
            <div class="card__body">
              <div style="background: var(--color-primary-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--color-primary-dark); margin-bottom: var(--space-4);">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              </div>
              <h3 class="card__title">Centro Pre CEPRE</h3>
              <p class="card__text">Ingreso directo para matriculados en el CEPRE UNDAC que alcancen vacante por estricto orden de mérito acumulado.</p>
              <ul class="check-list">
                <li>Matrícula en ciclo actual</li>
                <li>Promedio aprobatorio</li>
                <li>Sin cursos desaprobados</li>
              </ul>
            </div>
            <div class="card__footer">
              <a href="/modalidades" class="btn btn--outline" style="width: 100%;">Más información</a>
            </div>
          </div>

          <!-- Especiales -->
          <div class="card card--modality" style="border-top: 4px solid var(--color-accent-dark); padding-top: var(--space-2);">
            <div class="card__body">
              <div style="background: rgba(249, 168, 37, 0.1); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--color-accent-dark); margin-bottom: var(--space-4);">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
              </div>
              <h3 class="card__title">Modalidades Especiales</h3>
              <p class="card__text">Traslados externos, graduados, personas con discapacidad y deportistas calificados de alto rendimiento.</p>
              <ul class="check-list">
                <li>Resoluciones / certificados</li>
                <li>Documentación legalizada</li>
                <li>Ley universitaria vigente</li>
              </ul>
            </div>
            <div class="card__footer">
              <a href="/modalidades" class="btn btn--outline" style="width: 100%;">Ver opciones</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer slot="footer" />
</Layout>