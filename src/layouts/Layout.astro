---
export interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords = 'UNDAC, admisión, universidad, Pasco, Perú, ingreso, postulantes, carreras',
  ogImage = '/img/og-default.jpg'
} = Astro.props;

const siteUrl = 'https://admision.undac.edu.pe';
const currentPath = Astro.url.pathname;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Universidad Nacional Daniel Alcides Carrión" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`${siteUrl}${currentPath}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={`${siteUrl}${currentPath}`} />
  <meta property="og:site_name" content="Admisión UNDAC" />
  <meta property="og:locale" content="es_PE" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Favicon -->
  <link rel="icon" href="../../public/img/logo.jpg" />

  <!-- Styles -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" />

  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "Universidad Nacional Daniel Alcides Carrión",
    "alternateName": "UNDAC",
    "url": siteUrl,
    "logo": `${siteUrl}/img/logo-undac.png`,
    "description": "Universidad Nacional Daniel Alcides Carrión - Portal de Admisión",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Ciudad Universitaria, San Juan",
      "addressLocality": "Yanacancha",
      "addressRegion": "Pasco",
      "postalCode": "19001",
      "addressCountry": "PE"
    },
    "telephone": "(063) 421000",
    "email": "admision@undac.edu.pe"
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": siteUrl
      },
      ...(currentPath !== '/' ? [{
        "@type": "ListItem",
        "position": 2,
        "name": title.replace(' | Admisión UNDAC', ''),
        "item": `${siteUrl}${currentPath}`
      }] : [])
    ]
  })} />
</head>
<body>
  <slot name="header" />
  <main id="main-content" role="main">
    <slot />
  </main>
  <slot name="footer" />

  <!-- Scroll reveal -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    });
  </script>

</body>
</html>
